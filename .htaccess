RewriteEngine On

# Block direct access to .env files
<FilesMatch "^\.env(\..*)?$">
    Require all denied
</FilesMatch>

# If the requested file or directory actually exists, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise, route everything through index.php
RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]
